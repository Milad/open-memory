# ============================================================================
# 1. DATABASE CONNECTION
# ============================================================================
# Production note: keep the real `.env` untracked and set it to 0600.
# Note: When using Docker Compose, DB_HOST must match the service name 'db'
DB_CONNECTION_NAME=database
DB_HOST=db
DB_PORT=5432
DB_NAME=open_memory
DB_ADMIN_USER=memory_admin
DB_ADMIN_PASSWORD=change-me
DB_SSLMODE=prefer

# Dedicated least-privilege DB user for the MCP service.
MCP_DB_USER=memory_mcp
MCP_DB_PASSWORD=change-me
MCP_ALLOW_WRITES=true

# ============================================================================
# 2. EMBEDDING PROVIDER (VOYAGE AI)
# ============================================================================
EMBEDDING_ENABLED=true
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3

# ============================================================================
# 3. AUTHENTICATION & ACCESS
# ============================================================================
# Provider keys used by MCP and pgai vectorization. Keep real values only in
# untracked `.env` files.
PGEDGE_VOYAGE_API_KEY=

# INIT_TOKENS: Comma-separated list for Claude/Mobile access
INIT_TOKENS=

# ============================================================================
# 4. SERVER SETTINGS
# ============================================================================
HTTP_ENABLED=true
HTTP_ADDRESS=:8080
TLS_ENABLED=false
